{
  "name": "paper-trail",
  "version": "0.5.4",
  "private": true,
  "description": "A PDF reader with a list of navigation history stacks: browser-style back/forward plus cmd+click forking.",
  "type": "commonjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build && tsc -p tsconfig.node.json",
    "start": "node build-node/node/server.js",
    "desktop": "electron build-node/desktop/main.js",
    "test": "node build-node/test/e2e.js",
    "test:e2e:desktop": "node build-node/test/desktopE2e.js",
    "test:unit": "node --test build-node/test/unit.js",
    "test:desktop": "electron build-node/test/desktopSave.js",
    "test:offline": "electron build-node/test/desktopOffline.js",
    "test:autosave": "electron build-node/test/desktopAutosave.js",
    "test:install:win": "node build-node/test/installerWin.js",
    "test:install:mac": "node build-node/test/installerMac.js",
    "test:update:win": "node build-node/test/updateWin.js",
    "test:update:mac:install": "node build-node/test/updateMacInstall.js",
    "test:update:mac:manual-install": "node build-node/test/updateMacManualInstall.js",
    "test:stdio": "node build-node/test/desktopStdioClosed.js",
    "perf": "node build-node/tools/perf.js",
    "media": "node build-node/tools/media.js",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:win": "electron-builder --win --publish never",
    "icons": "node build-node/tools/icons.js",
    "pretest": "node build-node/tools/fixture.js"
  },
  "devDependencies": {
    "@playwright/browser-chromium": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200",
    "playwright-core": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-static-copy": "^4.1.1"
  },
  "main": "build-node/desktop/main.js",
  "author": "DE0CH",
  "build": {
    "appId": "local.paper-trail",
    "productName": "Paper Trail",
    "publish": {
      "provider": "github",
      "owner": "DE0CH",
      "repo": "paper-trail"
    },
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "build-node/**/*.js",
      "dist-web/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true,
      "target": [
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "fileAssociations": [
      {
        "ext": "pdf",
        "name": "PDF Document",
        "role": "Viewer",
        "mimeType": "application/pdf"
      },
      {
        "ext": "ptl",
        "name": "Paper Trail Reading Session",
        "role": "Editor",
        "icon": "ptl"
      }
    ]
  },
  "license": "MIT",
  "dependencies": {
    "electron-context-menu": "^3.6.1",
    "electron-updater": "^6.8.9",
    "koffi": "^3.1.1"
  }
}
